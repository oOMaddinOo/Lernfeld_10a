@page "/"
@inject IJSRuntime JS
@inject kloService kloService
@rendermode InteractiveServer

<PageTitle>Home</PageTitle>

<h1>Meine Karte</h1>

<div id="map" style="height: 500px; width: 100%;"></div>

<div class="mt-3">
    <div class="row">
        <div class="col-md-6">
            <div class="input-group mb-3">
                <input width="400" type="text" 
                       class="form-control" 
                       @bind="cityInput" 
                       placeholder="Enter city name (e.g., Berlin, München)"
                       @onkeypress="HandleKeyPress" />
                <button class="btn btn-success" @onclick="SearchCity">
                    <i class="bi bi-search"></i> Such in der Stadt
                </button>
                <button @onclick="AddToCommentToDatabase">Ein Eintrag Erstellen</button>
                <button @onclick="UpdateComment"> Klo Aktualisieren</button>
                <button @onclick="LoadAllToilets">Alle Toiletten Laden</button>
                <button @onclick="DeleteComment"> Klo Löschen</button>
                <button @onclick="loadOneKlo">Ein Klo Laden</button>
            </div>
        </div>
    </div>
    
    <div class="btn-group" role="group">
        <button class="btn btn-warning" @onclick="ClearMap">Clear Map</button>
    </div>
</div>

<div>
   <table>
       <thead>
        <th>Id</th>
        <th>Kommentar</th>
        <th>ElementId</th>
       </thead>
       <tbody>
           @if(allKloData.Any())
            {
                @foreach(var klo in allKloData)
                {
                    <tr>
                        <td>@klo.Id</td>
                        <td>@klo.Comment</td>
                        <td>@klo.ElementId</td>
                        <td>@klo.PictureUrl</td>
                    </tr>
                }
            }
        </tbody>
   </table>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3" style="max-width:400px;">@errorMessage</div>
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success mt-3" style="max-width:300px;">@successMessage</div>
}

@code {
    private string cityInput = string.Empty;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;
    private DatabaseKloModel kloData = new DatabaseKloModel();
    private List<DatabaseKloModel> allKloData = new List<DatabaseKloModel>();

    async Task SearchCity()
    {
        if (string.IsNullOrWhiteSpace(cityInput))
        {
            errorMessage = "Geben sie den namen einer Stadt ein.";
            successMessage = string.Empty;
            return;
        }

        await ClearMap();

        cityInput = char.ToUpper(cityInput[0]) + cityInput.Substring(1).ToLower();

        // Builder Pattern with User Input
        var queryBuilder = new ToiletQueryBuilder()
            .SetCity(cityInput);

        var result = await kloService.GetToilets(queryBuilder);
        var kloData = await kloService.GetAllKloData();
        await DisplayToilets(result, cityInput, kloData);
    }

    async Task ClearMap()
    {
        try
        {
            await JS.InvokeVoidAsync("clearMarkers");
            errorMessage = string.Empty;
            successMessage = string.Empty;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error clearing map: {ex.Message}");
        }
    }

    async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SearchCity();
        }
    }

    async Task DisplayToilets(KloModel result, string cityName, List<DatabaseKloModel> kloModels)
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;

        if (result == null)
        {
            errorMessage = $"Fehler beim laden von Toiletten daten {cityName}. Probier es noch einmal.";
            Console.WriteLine("Error: Result is null");
            return;
        }

        if (result.Elements == null || result.Elements.Count == 0)
        {
            errorMessage = $"Keine Toiletten gefunden in {cityName}.";
            Console.WriteLine("Warning: No elements found");
            return;
        }

        try
        {
            int markerCount = 0;
            foreach (var toilet in result.Elements)
            {
                string comment = "Kein Kommentar";
                string picture = "Kein Bild";
                var kloData = await  kloService.GetKloByElementId(toilet.ElementId);

                if (kloData != null &&  kloData.Comment != null )
                {
                    comment = kloData.Comment ;
                }

                if(kloData != null && kloData.PictureUrl != null)
                {
                    picture = kloData.PictureUrl;
                }

                if (toilet.Lat != null && toilet.Lon != null)
                {
                    await JS.InvokeVoidAsync("addMarker", toilet.ElementId, toilet.Lat, toilet.Lon, toilet.Type, toilet.Tags ?? new Dictionary<string, string>(), comment, picture);
                    markerCount++;
                }
            }

            successMessage = $"{markerCount} Toiletten in {cityName}!";

            if (result.Elements.Count > 0 && result.Elements[0].Lat != null && result.Elements[0].Lon != null)
            {
                await JS.InvokeVoidAsync("centerMap", result.Elements[0].Lat, result.Elements[0].Lon);
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error displaying toilets: {ex.Message}";
            Console.WriteLine($"Fehler: {ex.Message}");
        }
    }

    public async Task LoadAllToilets()
    {
        try
        {
            allKloData.Clear();
            List<DatabaseKloModel> allToilets = await kloService.GetAllKloData();
            foreach(var klo in allToilets)
            {
                allKloData.Add(klo);
                successMessage = "Alle Toiletten erfolgreich aus der Datenbank geladen";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Fehler beim Laden aller Toiletten aus der Datenbank: {ex.Message}";
        }
    }

    public async Task DeleteComment()
    {
        try
        {

            var toilets = await kloService.GetAllKloData();
            foreach(var klo in toilets)
            {         
                await kloService.DeleteKloDataComment(klo.Id);
                successMessage = "Klo erfolgreich gelöscht!";
                break;
            }
            await LoadAllToilets();
        }
        catch
        (Exception ex)
        {
            errorMessage = $"Fehler beim Löschen der Kommentare: {ex.Message}";
        }
    }

    public async Task loadOneKlo()
    {
        allKloData.Clear();
        var toilets = await kloService.GetAllKloData();
        foreach (var klo in toilets)
        {
            allKloData.Add(klo);
            break;
        }
    }

    public async Task UpdateComment()
    {
        try
        {       
            var toilets = await kloService.GetAllKloData();
            foreach(var klo in toilets)
            {
                klo.Comment = "Das geilste Klo das ich jemals hatte!!!";
                await kloService.UpdateCommentData(klo);
                break;
            }

            successMessage = "Kommentar erfolgreich aktualisiert!";
        }
        catch (Exception ex)
        {
            errorMessage = $"Fehler beim Aktualisieren des Kommentars: {ex.Message}";
        }
    }

    public async Task AddToCommentToDatabase()
    {
        string comment = "Ich habe diese Toilette benutzt und sie war sauber!";
        kloData.Comment = comment;

        kloData = new DatabaseKloModel
        {
            Id = Guid.NewGuid(),
           
            Comment = comment,
            PictureUrl = "https://waterdropstorage.blob.core.windows.net/picture/golden-toilet.jpg",
            ElementId = 9106108128
        };
        try
        {
            await kloService.AddKloCommentToData(kloData);
            successMessage = "Kommentar erfolgreich zur Datenbank hinzugefügt!";
            await LoadAllToilets();
        }
        catch (Exception ex)
        {
            errorMessage = $"Fehler beim Hinzufügen des Kommentars: {ex.Message}";
        }
    }


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initMap", 53.5801097, 9.8859876);
            cityInput = "Hamburg";

            var queryBuilder = new ToiletQueryBuilder()
                .SetCity(cityInput);

            var dataToilets = await kloService.GetAllKloData();

            var result = await kloService.GetToilets(queryBuilder);
            await DisplayToilets(result, cityInput, dataToilets);
            cityInput = string.Empty;
        }
    }
}